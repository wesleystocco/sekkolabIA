---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
import PostCard from '../components/PostCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import CaseCard from '../components/cases/CaseCard.astro';
import { getCollection } from 'astro:content';
import { 
  Cpu, TrendingUp, Zap, Target, Sparkles, Shield, 
  BookOpen, Image, Video, Mic, Code, Bot, Layers, ArrowRight 
} from 'lucide-astro';

// Buscar posts do blog e ordenar por data (mais recentes primeiro)
const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2); // pega os 2 mais recentes
---

<MainLayout title="SekkoLab IA – Do Zero ao Topo com Inteligência Artificial">
  <Hero />

  <!-- Seção: Diferenciais -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <h2 class="text-3xl md:text-4xl font-heading font-black text-white text-center mb-12">
      Por que <span class="text-primary">SekkoLab IA</span>?
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <FeatureCard icon={Cpu} title="Engenharia de Prompt" description="Aprenda a extrair o máximo de qualquer IA com técnicas avançadas de contexto." />
      <FeatureCard icon={TrendingUp} title="Resultados Reais" description="Foco em vendas, tráfego e carreira – não apenas teoria." />
      <FeatureCard icon={Zap} title="Atualização Constante" description="Novos conteúdos toda semana acompanhando o ritmo da IA." />
      <FeatureCard icon={Target} title="SEO e Tráfego Pago" description="Domine as ferramentas que realmente trazem visitantes e clientes." />
      <FeatureCard icon={Sparkles} title="Copywriting de Alta Conversão" description="Persuasão com IA para e-mails, anúncios e landing pages." />
      <FeatureCard icon={Shield} title="Carreira e Liderança" description="Use IA para se destacar no mercado e acelerar sua promoção." />
    </div>
  </section>

  <!-- Seção: Laboratórios Gratuitos (Cases) -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <h2 class="text-3xl md:text-4xl font-heading font-black text-white text-center mb-4">
      Laboratórios <span class="text-cyan-400">Gratuitos</span>
    </h2>
    <p class="text-center text-slate-400 mb-12 max-w-2xl mx-auto">
      Aplique na prática os conceitos com nossos mini‑cursos gratuitos. Cada laboratório é um mini‑ebook completo.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <CaseCard
        titulo="Instagram com IA"
        descricao="Do zero aos primeiros 1.000 seguidores em 30 dias"
        imagem="https://images.unsplash.com/photo-1611162617213-7d7a39e9b1d7?auto=format&fit=crop&q=80&w=800"
        slug="instagram"
        tempo="25 min"
        nivel="Iniciante"
      />
      <CaseCard
        titulo="YouTube Shorts"
        descricao="Primeiros $500 com vídeos curtos"
        imagem="https://images.unsplash.com/photo-1611162618071-b39a2ec055fb?auto=format&fit=crop&q=80&w=800"
        slug="shorts"
        tempo="30 min"
        nivel="Iniciante"
      />
      <CaseCard
        titulo="Nichamento Estratégico"
        descricao="Encontre seu nicho lucrativo em 7 dias"
        imagem="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=800"
        slug="nicho"
        tempo="20 min"
        nivel="Intermediário"
      />
      <CaseCard
        titulo="TikTok do Zero"
        descricao="Primeiro milhão de visualizações"
        imagem="https://images.unsplash.com/photo-1611162616475-46b635cb6868?auto=format&fit=crop&q=80&w=800"
        slug="tiktok"
        tempo="35 min"
        nivel="Iniciante"
      />
    </div>
  </section>

  <!-- Seção: Biblioteca de IA -->
  <section class="max-w-7xl mx-auto px-4 py-20 bg-gradient-to-br from-slate-900/50 to-slate-800/50 rounded-3xl mb-20">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-12">
      <div class="flex-1 text-center lg:text-left">
        <h2 class="text-3xl md:text-4xl font-heading font-black text-white mb-4">
          Biblioteca de <span class="text-cyan-400">IA</span>
        </h2>
        <p class="text-slate-400 text-lg mb-6 max-w-xl">
          Mais de 200 ferramentas de IA organizadas por categoria: chatbots, escrita, imagem, vídeo, áudio, automação e muito mais. Tudo em um só lugar.
        </p>
        <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
          <a href="/biblioteca" class="px-8 py-4 bg-cyan-500 text-white font-bold rounded-xl hover:bg-cyan-600 transition flex items-center gap-2">
            Explorar biblioteca <ArrowRight class="w-5 h-5" />
          </a>
          <a href="/recursos" class="px-8 py-4 border border-white/10 text-white font-bold rounded-xl hover:bg-white/5 transition">
            Ver recursos grátis
          </a>
        </div>
      </div>
      <div class="flex-1 grid grid-cols-3 gap-4 max-w-md">
        <div class="bg-slate-800/50 p-4 rounded-xl text-center">
          <div class="w-12 h-12 mx-auto mb-2 bg-cyan-500/20 rounded-xl flex items-center justify-center text-cyan-400">
            <Bot class="w-6 h-6" />
          </div>
          <span class="text-white font-semibold">60+</span>
          <span class="text-slate-400 text-xs block">Chatbots</span>
        </div>
        <div class="bg-slate-800/50 p-4 rounded-xl text-center">
          <div class="w-12 h-12 mx-auto mb-2 bg-cyan-500/20 rounded-xl flex items-center justify-center text-cyan-400">
            <Image class="w-6 h-6" />
          </div>
          <span class="text-white font-semibold">40+</span>
          <span class="text-slate-400 text-xs block">Imagem</span>
        </div>
        <div class="bg-slate-800/50 p-4 rounded-xl text-center">
          <div class="w-12 h-12 mx-auto mb-2 bg-cyan-500/20 rounded-xl flex items-center justify-center text-cyan-400">
            <Video class="w-6 h-6" />
          </div>
          <span class="text-white font-semibold">30+</span>
          <span class="text-slate-400 text-xs block">Vídeo</span>
        </div>
        <div class="bg-slate-800/50 p-4 rounded-xl text-center">
          <div class="w-12 h-12 mx-auto mb-2 bg-cyan-500/20 rounded-xl flex items-center justify-center text-cyan-400">
            <Mic class="w-6 h-6" />
          </div>
          <span class="text-white font-semibold">25+</span>
          <span class="text-slate-400 text-xs block">Áudio</span>
        </div>
        <div class="bg-slate-800/50 p-4 rounded-xl text-center">
          <div class="w-12 h-12 mx-auto mb-2 bg-cyan-500/20 rounded-xl flex items-center justify-center text-cyan-400">
            <Code class="w-6 h-6" />
          </div>
          <span class="text-white font-semibold">30+</span>
          <span class="text-slate-400 text-xs block">Programação</span>
        </div>
        <div class="bg-slate-800/50 p-4 rounded-xl text-center">
          <div class="w-12 h-12 mx-auto mb-2 bg-cyan-500/20 rounded-xl flex items-center justify-center text-cyan-400">
            <Layers class="w-6 h-6" />
          </div>
          <span class="text-white font-semibold">20+</span>
          <span class="text-slate-400 text-xs block">Plataformas</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Seção: Posts Recentes (dinâmicos) -->
  <section class="max-w-7xl mx-auto px-4 py-20 bg-white/5">
    <div class="flex items-center justify-between mb-12">
      <h2 class="text-3xl font-heading font-black text-white">Últimos do <span class="text-primary">Blog</span></h2>
      <a href="/blog" class="text-primary hover:underline text-sm font-bold">Ver todos →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {recentPosts.length > 0 ? (
        recentPosts.map(post => (
          <PostCard
            title={post.data.title}
            date={post.data.date}
            category={post.data.category}
            excerpt={post.data.excerpt}
            slug={post.slug}
            image={post.data.image}
          />
        ))
      ) : (
        <p class="text-slate-400 col-span-2 text-center">Nenhum post publicado ainda.</p>
      )}
    </div>
  </section>

  <!-- Seção: CTA Curso -->
  <section class="max-w-4xl mx-auto px-4 py-20 text-center">
    <h2 class="text-4xl md:text-5xl font-heading font-black text-white leading-tight">
      Comece sua <span class="text-primary">Trilha</span> hoje mesmo
    </h2>
    <p class="mt-4 text-slate-400 text-lg">
      Acesso imediato a +50 aulas, centenas de prompts e comunidade exclusiva.
    </p>
    <div class="mt-8">
      <a href="/cursos" class="inline-block px-8 py-4 bg-primary text-white font-bold rounded-xl text-lg hover:bg-primary/80 transition">
        Garantir minha vaga
      </a>
    </div>
  </section>

  <!-- Seção: Newsletter -->
  <section class="max-w-3xl mx-auto px-4 py-16 border-t border-white/5">
    <h3 class="text-2xl font-bold text-white text-center mb-4">Receba conteúdos exclusivos</h3>
    <NewsletterForm />
  </section>
</MainLayout>