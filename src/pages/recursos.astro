---
import MainLayout from '../layouts/MainLayout.astro';
import { Download, Mail, CheckCircle, Sparkles, TrendingUp, Target, Users, Zap, FileText } from 'lucide-astro';
---

<MainLayout title="Recursos Grátis – SekkoLab IA">
  <div class="max-w-7xl mx-auto px-4 py-16">
    <!-- Hero -->
    <div class="grid lg:grid-cols-2 gap-12 items-center mb-20">
      <div>
        <span class="inline-block px-3 py-1 bg-cyan-500/20 text-cyan-400 text-sm font-medium rounded-full mb-4">MATERIAL GRATUITO</span>
        <h1 class="text-4xl md:text-5xl font-heading font-black text-white leading-tight mb-4">
          Pack <span class="text-cyan-400">100 Prompts IA</span>
        </h1>
        <p class="text-xl text-slate-300 mb-6">
          Os prompts que usamos para criar conteúdo que vende. Prontos para copiar e colar.
        </p>
        <div class="flex flex-wrap gap-4 text-sm text-slate-400 mb-8">
          <span class="flex items-center gap-1"><CheckCircle class="w-4 h-4 text-cyan-400" /> 100% editável</span>
          <span class="flex items-center gap-1"><CheckCircle class="w-4 h-4 text-cyan-400" /> Atualizado 2026</span>
          <span class="flex items-center gap-1"><CheckCircle class="w-4 h-4 text-cyan-400" /> Uso comercial</span>
        </div>
      </div>
      <div class="relative">
        <img 
          src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&q=80&w=1200" 
          alt="Prompts IA" 
          class="rounded-2xl shadow-2xl border border-white/10"
        />
        <div class="absolute -bottom-4 -right-4 bg-cyan-500 text-white p-3 rounded-xl shadow-lg">
          <FileText class="w-6 h-6" />
        </div>
      </div>
    </div>

    <!-- Conteúdo do Pack -->
    <div class="grid md:grid-cols-2 gap-12 mb-20">
      <div>
        <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
          <Download class="w-6 h-6 text-cyan-400" /> Você vai baixar
        </h2>
        <div class="space-y-4">
          <div class="flex items-start gap-3 p-4 bg-slate-800/50 rounded-xl border border-white/5">
            <div class="w-10 h-10 rounded-lg bg-cyan-500/20 flex items-center justify-center text-cyan-400">
              <FileText class="w-5 h-5" />
            </div>
            <div>
              <h3 class="text-white font-semibold">50 prompts de copywriting</h3>
              <p class="text-sm text-slate-400">Headlines, e‑mails, anúncios, landing pages</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-4 bg-slate-800/50 rounded-xl border border-white/5">
            <div class="w-10 h-10 rounded-lg bg-cyan-500/20 flex items-center justify-center text-cyan-400">
              <TrendingUp class="w-5 h-5" />
            </div>
            <div>
              <h3 class="text-white font-semibold">20 prompts de SEO</h3>
              <p class="text-sm text-slate-400">Pesquisa de palavras‑chave, otimização on‑page</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-4 bg-slate-800/50 rounded-xl border border-white/5">
            <div class="w-10 h-10 rounded-lg bg-cyan-500/20 flex items-center justify-center text-cyan-400">
              <Zap class="w-5 h-5" />
            </div>
            <div>
              <h3 class="text-white font-semibold">15 prompts de produtividade</h3>
              <p class="text-sm text-slate-400">Gestão de equipes, automação de tarefas</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-4 bg-slate-800/50 rounded-xl border border-white/5">
            <div class="w-10 h-10 rounded-lg bg-cyan-500/20 flex items-center justify-center text-cyan-400">
              <Target class="w-5 h-5" />
            </div>
            <div>
              <h3 class="text-white font-semibold">10 prompts de análise de dados</h3>
              <p class="text-sm text-slate-400">Finanças, métricas, relatórios</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-4 bg-slate-800/50 rounded-xl border border-white/5">
            <div class="w-10 h-10 rounded-lg bg-cyan-500/20 flex items-center justify-center text-cyan-400">
              <Users class="w-5 h-5" />
            </div>
            <div>
              <h3 class="text-white font-semibold">5 prompts de carreira</h3>
              <p class="text-sm text-slate-400">LinkedIn, planejamento profissional</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Formulário de Captura -->
      <div class="bg-gradient-to-br from-slate-900 to-slate-800 rounded-3xl p-8 border border-white/5">
        <div class="flex items-center gap-2 mb-6">
          <Mail class="w-6 h-6 text-cyan-400" />
          <h2 class="text-2xl font-bold text-white">Receba seu pack agora</h2>
        </div>
        <p class="text-slate-300 mb-6">
          Preencha seu melhor e-mail e enviaremos o link de download imediatamente. 
          Você também receberá conteúdos exclusivos sobre IA.
        </p>

        <form id="leadForm" class="space-y-4">
          <input 
            type="email" 
            id="email"
            name="email" 
            required 
            placeholder="Seu melhor e-mail"
            class="w-full px-4 py-3 bg-slate-900 border border-white/10 rounded-xl text-white placeholder:text-slate-600 focus:outline-none focus:ring-2 focus:ring-cyan-500"
          />
          <button 
            type="submit"
            class="w-full px-6 py-3 bg-cyan-500 text-white font-bold rounded-xl hover:bg-cyan-600 transition flex items-center justify-center gap-2"
          >
            Quero receber <Download class="w-4 h-4" />
          </button>
        </form>
        <p class="text-xs text-slate-500 mt-4">
          Seus dados estão seguros. Prometemos não enviar spam.
        </p>

        <div id="successMessage" class="hidden mt-6 p-4 bg-green-500/20 border border-green-500/30 rounded-xl">
          <p class="text-green-400 font-medium">Pronto! Verifique seu e‑mail para baixar o pack.</p>
        </div>
        <div id="errorMessage" class="hidden mt-6 p-4 bg-red-500/20 border border-red-500/30 rounded-xl">
          <p class="text-red-400 font-medium">Ocorreu um erro. Tente novamente.</p>
        </div>
      </div>
    </div>

    <!-- O que você receberá por e-mail -->
    <div class="bg-cyan-500/10 border border-cyan-500/20 rounded-3xl p-8 text-center">
      <h2 class="text-2xl font-bold text-white mb-4">No e‑mail você vai receber</h2>
      <div class="grid md:grid-cols-3 gap-6 max-w-3xl mx-auto">
        <div class="p-4">
          <div class="w-12 h-12 mx-auto mb-3 bg-cyan-500/20 rounded-xl flex items-center justify-center text-cyan-400">
            <FileText class="w-6 h-6" />
          </div>
          <h3 class="text-white font-semibold">1. Link para download</h3>
          <p class="text-sm text-slate-400">Acesso imediato ao pack completo</p>
        </div>
        <div class="p-4">
          <div class="w-12 h-12 mx-auto mb-3 bg-cyan-500/20 rounded-xl flex items-center justify-center text-cyan-400">
            <Sparkles class="w-6 h-6" />
          </div>
          <h3 class="text-white font-semibold">2. Oferta exclusiva</h3>
          <p class="text-sm text-slate-400">Desconto especial para a Trilha IA</p>
        </div>
        <div class="p-4">
          <div class="w-12 h-12 mx-auto mb-3 bg-cyan-500/20 rounded-xl flex items-center justify-center text-cyan-400">
            <Mail class="w-6 h-6" />
          </div>
          <h3 class="text-white font-semibold">3. Conteúdos grátis</h3>
          <p class="text-sm text-slate-400">Dicas e novidades sobre IA</p>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  const form = document.getElementById('leadForm');
  const successMsg = document.getElementById('successMessage');
  const errorMsg = document.getElementById('errorMessage');
  const emailInput = document.getElementById('email');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();

    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    try {
      const response = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });

      if (response.ok) {
        successMsg.classList.remove('hidden');
        emailInput.value = '';
      } else {
        errorMsg.classList.remove('hidden');
      }
    } catch (err) {
      errorMsg.classList.remove('hidden');
    }
  });
</script>