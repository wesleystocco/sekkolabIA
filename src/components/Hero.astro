---
import { ArrowRight } from 'lucide-astro';
---

<section class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_#6366F1_0%,_transparent_50%)] opacity-20"></div>
  <div class="max-w-5xl mx-auto px-4 text-center relative z-10">
    <h1 class="text-5xl md:text-7xl font-heading font-black text-white leading-tight">
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">Trilha IA:</span> Do Zero ao Topo
    </h1>
    <p class="mt-6 text-xl text-slate-400 max-w-3xl mx-auto">
      Domine Marketing Digital, Vendas, Finanças e Carreira com Inteligência Artificial em 2026.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/recursos" class="px-8 py-4 bg-primary text-white font-bold rounded-xl hover:bg-primary/80 transition flex items-center justify-center gap-2">
        Baixar Prompts Grátis <ArrowRight class="w-5 h-5" />
      </a>
      <a href="/cursos" class="px-8 py-4 border border-white/10 text-white font-bold rounded-xl hover:bg-white/5 transition">
        Conhecer o Curso
      </a>
    </div>
  </div>
</section>