---
// src/components/cases/CaseCard.astro
export interface Props {
  titulo: string;
  descricao: string;
  imagem: string;
  slug: string;
  tempo: string;
  nivel: string;
}

const { titulo, descricao, imagem, slug, tempo, nivel } = Astro.props;
---

<a href={`/cases/${slug}`} class="group block bg-slate-900/50 border border-white/5 rounded-2xl overflow-hidden hover:border-cyan-500/50 transition-all hover:shadow-lg hover:shadow-cyan-500/5">
  <div class="h-48 overflow-hidden">
    <img src={imagem} alt={titulo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
  </div>
  <div class="p-6">
    <h3 class="text-xl font-heading font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">{titulo}</h3>
    <p class="text-sm text-slate-400 mb-4">{descricao}</p>
    <div class="flex items-center justify-between text-sm">
      <span class="text-slate-500">{tempo}</span>
      <span class="text-cyan-400">{nivel}</span>
    </div>
  </div>
</a>