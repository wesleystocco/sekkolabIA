---
// src/components/curso/AtividadePratica.astro
interface Props {
  id: string;
  titulo: string;
  descricao: string;
  tipo: 'texto' | 'prompt' | 'analise';
  exemplo?: string;
  pontos: number;
  placeholder?: string;
}

const { id, titulo, descricao, tipo, exemplo, pontos, placeholder } = Astro.props;

const tipoConfig = {
  texto: { icone: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', cor: 'from-purple-500 to-pink-500' },
  prompt: { icone: 'M13 10V3L4 14h7v7l9-11h-7z', cor: 'from-blue-500 to-cyan-500' },
  analise: { icone: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', cor: 'from-amber-500 to-orange-500' }
};

const config = tipoConfig[tipo];
---

<div class="atividade-container bg-slate-800/50 rounded-2xl p-6 border border-white/5" data-atividade-id={id} data-pontos={pontos}>
  <!-- Header -->
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
      <div class={`w-12 h-12 rounded-2xl bg-gradient-to-br ${config.cor} flex items-center justify-center shadow-lg`}>
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={config.icone}/>
        </svg>
      </div>
      <div>
        <h4 class="text-white font-bold">{titulo}</h4>
        <p class="text-xs text-slate-400 capitalize">{tipo === 'prompt' ? 'Crie um prompt' : tipo === 'analise' ? 'Analise um caso' : 'Responda'}</p>
      </div>
    </div>
    <div class="text-right">
      <div class="text-xl font-bold text-amber-400">+{pontos}</div>
      <div class="text-xs text-slate-400">pontos</div>
    </div>
  </div>
  
  <!-- Descrição -->
  <p class="text-slate-300 mb-4">{descricao}</p>
  
  <!-- Exemplo -->
  {exemplo && (
    <div class="mb-4 p-4 bg-slate-900/50 rounded-xl border-l-4 border-cyan-500">
      <p class="text-xs text-cyan-400 font-medium mb-1">EXEMPLO</p>
      <p class="text-sm text-slate-300">{exemplo}</p>
    </div>
  )}
  
  <!-- Campo de resposta -->
  <textarea 
    id={`atividade-input-${id}`}
    class="w-full p-4 bg-slate-900 border border-white/10 rounded-xl text-white placeholder-slate-500 focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-all resize-none" 
    rows="6"
    placeholder={placeholder || 'Digite sua resposta aqui...'}
  ></textarea>
  
  <!-- Contador de caracteres -->
  <div class="flex items-center justify-between mt-3">
    <span id={`atividade-contador-${id}`} class="text-xs text-slate-500">0 caracteres (mínimo 50)</span>
    <button id={`atividade-submit-${id}`} class="px-6 py-2 bg-gradient-to-r from-cyan-500 to-blue-500 text-white font-semibold rounded-xl hover:from-cyan-400 hover:to-blue-400 transition-all shadow-lg shadow-cyan-500/30 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
      Enviar Atividade
    </button>
  </div>
  
  <!-- Feedback (oculto) -->
  <div id={`atividade-feedback-${id}`} class="hidden mt-4 p-4 bg-green-500/20 border border-green-500/50 rounded-xl">
    <div class="flex items-center gap-2">
      <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
      <p class="text-green-400 font-medium">Atividade enviada com sucesso!</p>
    </div>
  </div>
</div>

<script define:vars={{ id, pontos }}>
  // Garantir que o DOM esteja carregado
  window.addEventListener('DOMContentLoaded', function() {
    const textarea = document.getElementById('atividade-input-' + id);
    const submit = document.getElementById('atividade-submit-' + id);
    const contador = document.getElementById('atividade-contador-' + id);
    const feedback = document.getElementById('atividade-feedback-' + id);
    
    if (!textarea || !submit) return;
    
    textarea.addEventListener('input', function() {
      var length = textarea.value.length;
      if (contador) {
        contador.textContent = length + ' caracteres (mínimo 50)';
        if (length >= 50) {
          contador.className = 'text-xs text-green-400';
        } else {
          contador.className = 'text-xs text-slate-500';
        }
      }
      submit.disabled = length < 50;
    });
    
    submit.addEventListener('click', function() {
      if (textarea.value.length >= 50) {
        // Feedback visual
        submit.textContent = 'Enviado!';
        submit.classList.remove('bg-gradient-to-r', 'from-cyan-500', 'to-blue-500');
        submit.classList.add('bg-green-500');
        submit.disabled = true;
        textarea.disabled = true;
        
        if (feedback) feedback.classList.remove('hidden');
        
        // Emitir evento
        var event = new CustomEvent('pontos-ganhos', { detail: { pontos: pontos, tipo: 'atividade' } });
        document.dispatchEvent(event);
        var event2 = new CustomEvent('atividade-concluida', { detail: { id: id } });
        document.dispatchEvent(event2);
      }
    });
  });
</script>