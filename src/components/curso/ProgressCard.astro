---
// src/components/curso/ProgressCard.astro
interface Props {
  modulo: {
    id: string;
    titulo: string;
    subtitulo?: string;
    tempo: number;
    tipo: 'leitura' | 'video' | 'quiz' | 'atividade';
    pontos: number;
    imagem?: string;
  };
  concluido: boolean;
  ativo: boolean;
}

const { modulo, concluido, ativo } = Astro.props;

const tipoConfig = {
  leitura: { cor: 'from-blue-500/20 to-cyan-500/20', icone: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253', badge: 'Leitura' },
  video: { cor: 'from-purple-500/20 to-pink-500/20', icone: 'M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z', badge: 'Vídeo' },
  quiz: { cor: 'from-green-500/20 to-emerald-500/20', icone: 'M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', badge: 'Quiz' },
  atividade: { cor: 'from-amber-500/20 to-orange-500/20', icone: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', badge: 'Prática' }
};

const config = tipoConfig[modulo.tipo];
---

<div 
  class={`progress-card group relative overflow-hidden rounded-2xl transition-all duration-500 cursor-pointer ${
    ativo 
      ? 'ring-2 ring-cyan-500 shadow-lg shadow-cyan-500/20' 
      : 'opacity-60 hover:opacity-80'
  }`}
  data-modulo-id={modulo.id}
>
  <!-- Background -->
  <div class={`absolute inset-0 bg-gradient-to-br ${config.cor} ${concluido ? 'opacity-30' : 'opacity-100'}`}></div>
  
  <!-- Conteúdo -->
  <div class="relative p-5">
    <!-- Header -->
    <div class="flex items-start justify-between mb-3">
      <div class="flex items-center gap-2">
        <div class={`w-8 h-8 rounded-lg flex items-center justify-center ${concluido ? 'bg-green-500' : 'bg-white/10'}`}>
          {concluido ? (
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          ) : (
            <span class="text-xs text-white/70">{modulo.id}</span>
          )}
        </div>
        <span class="text-xs font-medium px-2 py-0.5 rounded bg-white/10 text-white/70">{config.badge}</span>
      </div>
      
      <div class="text-right">
        <div class="text-lg font-bold text-amber-400">+{modulo.pontos}</div>
        <div class="text-xs text-slate-400">pts</div>
      </div>
    </div>
    
    <!-- Título -->
    <h3 class="text-white font-bold text-lg mb-1 group-hover:text-cyan-400 transition-colors">{modulo.titulo}</h3>
    {modulo.subtitulo && <p class="text-slate-400 text-sm mb-3">{modulo.subtitulo}</p>}
    
    <!-- Imagem (se houver) -->
    {modulo.imagem && (
      <div class="mb-3 rounded-xl overflow-hidden">
        <img src={modulo.imagem} alt={modulo.titulo} class="w-full h-32 object-cover" />
      </div>
    )}
    
    <!-- Footer -->
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-1 text-slate-400 text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span>{modulo.tempo} min</span>
      </div>
      
      <div class={`px-3 py-1 rounded-full text-sm font-medium transition-all ${
        ativo 
          ? 'bg-cyan-500 text-white' 
          : concluido 
            ? 'bg-green-500/20 text-green-400' 
            : 'bg-white/10 text-white/70'
      }`}>
        {concluido ? 'Revisar' : ativo ? 'Continuar' : 'Iniciar'}
      </div>
    </div>
  </div>
  
  <!-- Efeito de hover -->
  <div class="absolute inset-0 bg-gradient-to-r from-cyan-500/0 via-cyan-500/5 to-cyan-500/0 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000"></div>
</div>