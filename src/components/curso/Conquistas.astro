---
// src/components/curso/Conquistas.astro
interface Props {
  conquistas: Array<{ id: string; nome: string; icone: string; descricao: string; desbloqueada: boolean }>;
}

const { conquistas } = Astro.props;
---

<div id="conquistas-panel" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg p-6">
    <div class="bg-slate-900 border border-white/10 rounded-3xl p-6 shadow-2xl">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-xl font-bold text-white">Conquistas</h3>
        <button id="fechar-conquistas" class="text-slate-400 hover:text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      
      <div class="grid grid-cols-3 gap-4">
        {conquistas.map((c) => (
          <div class={`p-4 rounded-xl text-center ${c.desbloqueada ? 'bg-gradient-to-br from-amber-500/20 to-orange-500/20 border border-amber-500/30' : 'bg-slate-800/50 border border-white/5 opacity-50'}`}>
            <div class="text-3xl mb-2">{c.icone}</div>
            <p class="text-white text-sm font-medium">{c.nome}</p>
            <p class="text-slate-500 text-xs mt-1">{c.descricao}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>