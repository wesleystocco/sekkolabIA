---
// src/components/curso/Breadcrumb.astro
interface Props {
  items: Array<{ label: string; href?: string }>;
}
const { items } = Astro.props;
---
<nav class="flex items-center gap-2 text-sm mb-6 overflow-x-auto pb-2">
  {items.map((item, index) => (
    <div class="flex items-center gap-2 flex-shrink-0">
      {index > 0 && (
        <svg class="w-4 h-4 text-slate-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      )}
      {item.href ? (
        <a href={item.href} class="text-slate-400 hover:text-cyan-400 transition-colors whitespace-nowrap">
          {item.label}
        </a>
      ) : (
        <span class="text-white font-medium whitespace-nowrap">{item.label}</span>
      )}
    </div>
  ))}
</nav>