---
export interface Props {
  titulo: string;
  descricao: string;
  cargaHoraria: number;
  slug: string;
  gratuito?: boolean;
}

const { titulo, descricao, cargaHoraria, slug, gratuito = false } = Astro.props;
---

<a href={`/cursos-gratuitos/${slug}`} class="group block bg-slate-900/50 border border-white/5 rounded-2xl p-6 hover:border-primary/50 transition-all hover:shadow-lg hover:shadow-primary/5">
  {gratuito && (
    <span class="inline-block px-3 py-1 bg-accent/20 text-accent text-xs font-bold rounded-full mb-4">GRATUITO</span>
  )}
  <h3 class="text-xl font-heading font-bold text-white mb-2 group-hover:text-primary transition-colors">{titulo}</h3>
  <p class="text-sm text-slate-400 mb-4">{descricao}</p>
  <div class="flex items-center justify-between text-sm">
    <span class="text-slate-500">{cargaHoraria}h de conteúdo</span>
    <span class="text-primary group-hover:translate-x-1 transition-transform">Acessar →</span>
  </div>
</a>